TELEGRAM_BOT_TOKEN=put_your_botfather_token_here
GROQ_API_KEY=put_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
BOT_NAME=Symbat AI
SYSTEM_PROMPT=You are a helpful, warm Telegram assistant. Answer clearly and briefly.

# Optional: comma-separated Telegram user IDs allowed to approve actions.
# If empty, only the person who requested an action can approve it.
APPROVER_USER_IDS=

# Optional: safe external servers the bot may call after approval.
# Keep this as valid JSON on one line.
# Example:
# CONNECTORS_JSON=[{"name":"nora","url":"https://example.com/telegram-task","token":"secret","requiresApproval":true}]
CONNECTORS_JSON=[]

# Optional: set to false if you only want manual /remember memory.
AUTO_MEMORY=true

# Optional: write-action tools. These only run after /approve.
# Put real values in Railway Variables, not in GitHub.
GITHUB_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
RAILWAY_DEPLOY_HOOK_URL=
